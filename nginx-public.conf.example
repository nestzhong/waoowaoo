# 公网服务器 Nginx 配置示例
# 用于将内网应用通过子路径暴露到公网
#
# 场景：
# - 内网服务器部署 Docker 应用（端口 13000）
# - 公网服务器有域名 iot-test.wasumedia.cn 和 SSL 证书
# - 通过此配置将 https://iot-test.wasumedia.cn/waoowaoo 转发到内网
#
# 使用方式：
# 1. 修改 server_name 为实际域名
# 2. 修改 ssl_certificate 路径为实际证书路径
# 3. 修改 proxy_pass 为内网服务器 IP 或域名

server {
    listen 443 ssl http2;
    server_name iot-test.wasumedia.cn;

    ssl_certificate /path/to/fullchain.pem;
    ssl_certificate_key /path/to/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # 子路径转发到内网服务器
    # 注意：proxy_pass 后面不加路径，保留原始 URI
    location /waoowaoo {
        proxy_pass http://<内网服务器IP>;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix /waoowaoo;

        # WebSocket 支持
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # 超时配置
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        client_max_body_size 100m;
    }

    # 可选：根路径重定向到应用
    location = / {
        return 302 /waoowaoo;
    }
}

# HTTP 重定向到 HTTPS
server {
    listen 80;
    server_name iot-test.wasumedia.cn;
    return 301 https://$host$request_uri;
}
